# =============================================================================
# AI-Powered Retail Analytics — Environment Configuration
# Copy to .env and fill in values:  cp .env.example .env
# =============================================================================

# --- Gemini AI (required for generate_ai_insights task) ---
GEMINI_API_KEY=your_api_key_here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TEMPERATURE=0.3
GEMINI_MAX_OUTPUT_TOKENS=4096
GEMINI_MAX_RETRIES=3

# --- PostgreSQL (Airflow metadata DB) ---
POSTGRES_USER=airflow
POSTGRES_PASSWORD=airflow
POSTGRES_DB=airflow

# --- Airflow ---
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=
AIRFLOW_ADMIN_USER=airflow
AIRFLOW_ADMIN_PASSWORD=airflow
AIRFLOW_ADMIN_EMAIL=admin@example.com
AIRFLOW_PORT=8080
AIRFLOW_UID=50000
RETAIL_DAG_SCHEDULE=0 6 * * *

# --- Frontend ---
FRONTEND_PORT=3000

# --- Pipeline timeouts (optional overrides) ---
# TIMEOUT_BRONZE_HOURS=3
# TIMEOUT_SILVER_HOURS=4
# TIMEOUT_GOLD_HOURS=2
