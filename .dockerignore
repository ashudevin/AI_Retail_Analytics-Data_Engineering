frontend/node_modules
frontend/.next
frontend/out

# Airflow runtime
airflow/logs/
airflow/airflow.db
airflow/airflow.cfg
airflow/webserver_config.py

# Secrets
.env
.env.local

# IDE & OS
.idea
.vscode
.DS_Store
Thumbs.db

# Notebooks
.ipynb_checkpoints
notebooks/

# Docker meta
docker-compose.override.yml
